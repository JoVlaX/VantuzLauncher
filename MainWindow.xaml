<Window x:Class="VantuzLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vantuz Launcher" Height="550" Width="850"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseDown="Window_MouseDown">
    <Border Background="#09090B" CornerRadius="12" BorderBrush="#27272A" BorderThickness="1">
        <Grid>
            <!-- Settings Gear Button (Top Left) -->
            <Button HorizontalAlignment="Left" VerticalAlignment="Top" Width="40" Height="40" Margin="10"
                    Background="Transparent" BorderThickness="0" Foreground="#3F3F46" Click="BtnSettings_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" x:Name="bgBorder" CornerRadius="6">
                            <Path Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61 l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41 h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87 C2.62,9.08,2.66,9.34,2.85,9.48l2.03,1.58C4.84,11.36,4.81,11.69,4.81,12s0.02,0.64,0.07,0.94l-2.03,1.58 c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54 c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96 c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6 s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" 
                                  Fill="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="18" Height="18"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bgBorder" Property="Background" Value="#18181B" />
                                <Setter Property="Foreground" Value="#71717A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Close Custom Button (Top Right) -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="40" Height="40" Margin="10"
                    Background="Transparent" BorderThickness="0" Foreground="#A1A1AA" Content="✕"
                    Click="BtnClose_Click" Cursor="Hand" FontSize="16">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" x:Name="bgBorder" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bgBorder" Property="Background" Value="#27272A" />
                                <Setter Property="Foreground" Value="#F4F4F5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Main UI -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
                
                <!-- Logo -->
                <TextBlock Text="VANTUZ" FontSize="42" FontWeight="Black" Foreground="#F4F4F5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <TextBlock Text="M I N E C R A F T" FontSize="12" FontWeight="SemiBold" Foreground="#71717A" HorizontalAlignment="Center" Margin="0,0,0,50"/>

                <!-- Username -->
                <TextBlock Text="ЛОГИН" Foreground="#A1A1AA" FontSize="11" Margin="0,0,0,8" FontWeight="SemiBold"/>
                <Border Background="#18181B" CornerRadius="8" BorderBrush="#27272A" BorderThickness="1" Margin="0,0,0,20" Height="48">
                    <TextBox x:Name="UsernameBox" Background="Transparent" Foreground="#F4F4F5" BorderThickness="0"
                             Padding="14,12" FontSize="15" VerticalContentAlignment="Center" CaretBrush="#F4F4F5"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="ПАРОЛЬ" Foreground="#A1A1AA" FontSize="11" Margin="0,0,0,8" FontWeight="SemiBold"/>
                <Border Background="#18181B" CornerRadius="8" BorderBrush="#27272A" BorderThickness="1" Margin="0,0,0,15" Height="48">
                    <PasswordBox x:Name="PasswordBox" Background="Transparent" Foreground="#F4F4F5" BorderThickness="0"
                                 Padding="14,12" FontSize="15" VerticalContentAlignment="Center" CaretBrush="#F4F4F5"/>
                </Border>

                <!-- Remember Me -->
                <CheckBox x:Name="RememberMeBox" Content="Запомнить меня" Foreground="#71717A" Margin="0,0,0,30" FontSize="13">
                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="18" Height="18" Background="#18181B" BorderBrush="#27272A" BorderThickness="1" CornerRadius="4" x:Name="checkBorder">
                                                <Path x:Name="checkMark" Data="M0,4.5 L3.5,8 L10,0" Stroke="#09090B" StrokeThickness="2.5" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,1,0,0"/>
                                            </Border>
                                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="checkBorder" Property="Background" Value="#F4F4F5"/>
                                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                <Setter Property="Foreground" Value="#F4F4F5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>
                </CheckBox>

                <!-- Play Button -->
                <Button x:Name="BtnPlay" Height="52" Cursor="Hand" Click="BtnPlay_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#F4F4F5" CornerRadius="8" x:Name="btnBorder">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#FFFFFF" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#3F3F46" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="ИГРАТЬ" Foreground="#09090B" FontWeight="Bold" FontSize="15" x:Name="BtnPlayText"/>
                </Button>

                <!-- Progress / Status Panel -->
                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,25,0,0">
                    <TextBlock x:Name="StatusText" Text="Подготовка к запуску..." Foreground="#A1A1AA" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <ProgressBar x:Name="LauncherProgress" Height="4" Background="#18181B" Foreground="#F4F4F5" BorderThickness="0" Maximum="100"/>
                </StackPanel>
            </StackPanel>

            <!-- Settings Panel Overlay -->
            <Grid x:Name="SettingsPanel" Visibility="Collapsed" Background="#CC09090B">
                <Border Background="#18181B" CornerRadius="12" BorderBrush="#27272A" BorderThickness="1" 
                        Width="340" Height="280" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Margin="24">
                        <Grid Margin="0,0,0,24">
                            <TextBlock Text="НАСТРОЙКИ" Foreground="#F4F4F5" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#A1A1AA" 
                                    Content="✕" Click="BtnCloseSettings_Click" Cursor="Hand" FontSize="16"/>
                        </Grid>

                        <TextBlock Text="ВЫДЕЛЕНИЕ ОЗУ" Foreground="#A1A1AA" FontSize="11" Margin="0,0,0,12" FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,8">
                            <Slider x:Name="RamSlider" Minimum="1024" Maximum="16384" SmallChange="512" LargeChange="1024" 
                                    Value="4096" TickFrequency="512" IsSnapToTickEnabled="True"
                                    ValueChanged="RamSlider_ValueChanged" VerticalAlignment="Center" Margin="0,0,0,30"/>
                            <TextBlock x:Name="RamText" Text="Выделено: 4096 МБ из 8192 МБ" Foreground="#F4F4F5" FontSize="11" 
                                       HorizontalAlignment="Left" VerticalAlignment="Bottom" FontWeight="Bold" Margin="0,0,0,5"/>
                        </Grid>
                        <TextBlock Text="Установите объем памяти для Minecraft" Foreground="#71717A" FontSize="11" Margin="0,0,0,30"/>
                        
                        <TextBlock Text="ВЕРСИЯ ЛАУНЧЕРА" Foreground="#A1A1AA" FontSize="11" Margin="0,0,0,4" FontWeight="SemiBold"/>
                        <TextBlock x:Name="VersionText" Text="v20260503.1200" Foreground="#71717A" FontSize="11"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>