{ 
   "variables": { 
     "localVersion": "2.0-dev",
     "gameVersion": "1.20.1-forge-47.2.20"
   }, 
   "plugins": { 
     "Vantuz.Plugins.Auth.dll": "", 
     "Vantuz.Plugins.Net.dll": "", 
     "Vantuz.Plugins.OS.dll": "", 
     "Vantuz.Plugins.Game.dll": "" 
   }, 
   "pipeline": [ 
     { 
       "pluginName": "Net.ApiReader", 
       "config": { 
         "url": "https://troglobit.webhm.pro/launcher_version.txt", 
         "payloadKey": "remoteVersion", 
         "ignoreSslErrors": true, 
         "fallback": "2.0-dev" 
       } 
     }, 
     { 
       "pluginName": "Net.Updater", 
       "config": { 
         "url": "https://troglobit.webhm.pro/launcher.zip", 
         "currentVersion": "{{localVersion}}", 
         "targetVersion": "{{remoteVersion}}", 
         "scriptName": "update.bat" 
       } 
     }, 
     { 
       "pluginName": "Auth.Yggdrasil", 
       "config": { 
         "url": "https://troglobit.webhm.pro/yggdrasil/authserver/authenticate", 
         "ignoreSslErrors": true, 
         "launcherVersion": "{{remoteVersion}}" 
       } 
     }, 
     { 
       "pluginName": "Game.ManifestBuilder", 
       "config": { 
         "versionName": "{{gameVersion}}" 
       } 
     }, 
     { "pluginName": "OS.DeltaAnalyzer", "config": {} },       
     { "pluginName": "OS.LocalMover", "config": {} },          
     { "pluginName": "Net.BatchDownloader", "config": {} },    
     { "pluginName": "OS.BatchPurger", "config": {} }, 
     { 
       "pluginName": "Game.CmlLaunch", 
       "config": { 
         "versionName": "{{gameVersion}}", 
         "authlibPath": "{{mcDir}}\\authlib-injector.jar" 
       } 
     }, 
     { 
       "pluginName": "OS.Executor", 
       "config": { 
         "fileName": "{{gameCommand}}", 
         "arguments": "{{gameArgs}}", 
         "workDir": "{{gameWorkDir}}", 
         "waitForExit": false 
       } 
     } 
   ] 
 } 
